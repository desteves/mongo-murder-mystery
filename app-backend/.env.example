# MongoDB Murder Mystery - Backend Environment Variables
# Copy this file to .env and fill in the actual values

# ============================================
# REQUIRED VARIABLES
# ============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/mmm

# Internal API key for securing endpoints
INTERNAL_API_KEY=your-secret-api-key-here

# Salt for hashing (used for mystery validation)
SALT=your-random-salt-here

# Clue for the crime scene
CLUE_CRIME=your-crime-clue-here

# ============================================
# RECOMMENDED VARIABLES
# ============================================

# Allowed CORS origin (frontend URL)
ALLOWED_ORIGIN=http://localhost:8080

# MongoDB database name (default: mmm)
MONGODB_DBNAME=mmm

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Server port (default: 8080)
PORT=8080

# MongoDB connection pool settings
MONGODB_MAX_POOL=20
MONGODB_MIN_POOL=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=20000

# Request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Additional mystery clues (optional)
CLUE_WITNESS1=your-witness1-clue-here
CLUE_WITNESS2=your-witness2-clue-here
CLUE_SUSPECT=your-suspect-clue-here

# ============================================
# AGENT ENDPOINT VARIABLES (Optional)
# Only required if you want to use the /agent endpoint
# ============================================

# OpenAI API key (for OpenRouter)
OPENAI_API_KEY=your-openai-api-key-here

# MongoDB MCP connection string
MDB_MCP_CONNECTION_STRING=mongodb://localhost:27017/mmm

# MCP server URL
MCP_SERVER_URL=http://localhost:3001/mcp

# MCP database name (default: mmm)
MCP_DATABASE=mmm

# OpenAI model to use (default: tngtech/deepseek-r1t2-chimera:free)
OPENAI_MODEL=tngtech/deepseek-r1t2-chimera:free

# MCP ID token audience (for Google Cloud authentication)
MCP_ID_TOKEN_AUDIENCE=http://localhost:3001/mcp

# MCP connection string (alternative to MDB_MCP_CONNECTION_STRING)
MCP_CONNECTION_STRING=mongodb://localhost:27017/mmm

