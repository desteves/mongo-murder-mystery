# MongoDB Murder Mystery - Frontend Environment Variables
# Copy this file to .env and fill in the actual values

# ============================================
# REQUIRED VARIABLES
# ============================================

# Backend API base URL
VITE_MMM_API_BASE_URL=https://mmm-be-1020079043644.us-central1.run.app

# API key for authenticating with the backend (must match INTERNAL_API_KEY in backend)
VITE_MMM_API_KEY=mmm-frontend-M4rCHm4ddn3$$-2026

# ============================================
# DEVELOPMENT VARIABLES
# ============================================

# For local development, use:
# VITE_MMM_API_BASE_URL=http://localhost:8080
# VITE_MMM_API_KEY=your-local-api-key

# ============================================
# NOTES
# ============================================
# - All frontend environment variables MUST be prefixed with VITE_ to be exposed to the client
# - The VITE_MMM_API_KEY must match the INTERNAL_API_KEY set in the backend
# - See ENV_VARIABLES.md in the project root for complete documentation
